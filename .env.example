# ─────────────────────────────────────────────────────────────────────
#  Loki AI for Byggkon — komplett liste over miljøvariabler
# ─────────────────────────────────────────────────────────────────────
#  Hver linje matcher én innstilling i admin-UI. Hemmeligheter er markert
#  med "🔒 secret". Felt merket "⚙ restart" krever omstart for å ta effekt.
#
#  På Railway: Settings → Variables. Bruk scripts/railway-vars.sh til å
#  sette hele settet på én gang uten å overskrive verdier du allerede
#  har lagt inn.

# ─────────────────────────────────────────────────────────────────────
# 1. MICROSOFT GRAPH                                       (alle ⚙ restart)
# ─────────────────────────────────────────────────────────────────────
# Fra Entra ID app registration. Trenger Application permissions:
#   Files.Read.All, User.Read.All, (Sites.Read.All for SharePoint)
# Husk å klikke "Grant admin consent".
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=                              # 🔒 secret
# Avanserte (la stå tomme i 99% av tilfeller):
GRAPH_AUTHORITY=https://login.microsoftonline.com
GRAPH_SCOPE=https://graph.microsoft.com/.default
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0

# ─────────────────────────────────────────────────────────────────────
# 2. SYNKRONISERING — HVA SKAL INDEKSERES
# ─────────────────────────────────────────────────────────────────────
# all_users                     = alle OneDrives i tenanten
# all_users_and_sharepoint      = + alle SharePoint document libraries
# users_csv                     = bruk SYNC_USERS som hvitliste
# drives_csv                    = bruk SYNC_DRIVE_IDS som hvitliste
SYNC_SCOPE=all_users
SYNC_USERS=                                       # eks: alice@byggkon.no,bob@byggkon.no
SYNC_DRIVE_IDS=                                   # eks: drive-id-1,drive-id-2
SYNC_PATH_PREFIX=                                 # eks: /Documents/Knowledge
MAX_FILE_BYTES=52428800                           # 50 MB

# ─────────────────────────────────────────────────────────────────────
# 3. TIDSPLAN
# ─────────────────────────────────────────────────────────────────────
SYNC_INTERVAL_MINUTES=10
SYNC_CRON=                                        # tom = bruk intervall ovenfor
SYNC_ON_STARTUP=true

# ─────────────────────────────────────────────────────────────────────
# 4. EMBEDDING-PROVIDER
# ─────────────────────────────────────────────────────────────────────
# openai  = kun OpenAI (kun tekst)
# gemini  = kun Gemini Embedding 2 (multimodal: tekst + bilder + lyd + video)
# both    = skriv parallelt til begge — to separate Pinecone-indekser
EMBEDDING_PROVIDER=openai
EMBEDDING_BATCH_SIZE=64

# ─── 4a. OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=                                   # 🔒 secret
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072                  # ⚙ restart

# ─── 4b. Gemini Embedding 2 (Google AI Studio) ───────────────────────
# Hent API-nøkkel fra https://aistudio.google.com/apikey
GEMINI_API_KEY=                                   # 🔒 secret
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_EMBEDDING_DIMENSIONS=3072                  # 128/768/1536/3072 (Matryoshka). ⚙ restart
GEMINI_EMBED_IMAGES=true                          # send bilder fra PDF-er som bytes

# ─────────────────────────────────────────────────────────────────────
# 5. PINECONE
# ─────────────────────────────────────────────────────────────────────
PINECONE_API_KEY=                                 # 🔒 secret  ⚙ restart
# To separate indekser — én per provider. Kan ha forskjellig dimensjon.
PINECONE_INDEX_OPENAI=byggkon-openai              # ⚙ restart
PINECONE_INDEX_GEMINI=byggkon-gemini              # ⚙ restart
# Legacy (bakoverkompatibel, brukes som fallback for OpenAI):
PINECONE_INDEX=                                   # ⚙ restart
# Tom = drive_id som namespace per drive (anbefalt). Sett for ett delt namespace:
PINECONE_NAMESPACE=

# ─────────────────────────────────────────────────────────────────────
# 6. UNSTRUCTURED / CHUNKING
# ─────────────────────────────────────────────────────────────────────
# auto = hi_res for PDF/bilder, fast for resten
UNSTRUCTURED_STRATEGY=auto
UNSTRUCTURED_CHUNK_MAX_CHARS=1500
UNSTRUCTURED_CHUNK_OVERLAP=150

# ─────────────────────────────────────────────────────────────────────
# 7. SYSTEM
# ─────────────────────────────────────────────────────────────────────
STATE_DIR=/data                                   # ⚙ restart  Mount Railway Volume her
TMP_DIR=/tmp/onedrive-sync
LOG_LEVEL=INFO                                    # DEBUG | INFO | WARNING | ERROR
PROCESS_CONCURRENCY=2
PORT=8000                                         # Railway setter dette automatisk

# ─────────────────────────────────────────────────────────────────────
# 8. ADMIN
# ─────────────────────────────────────────────────────────────────────
# UTEN ADMIN_PASSWORD er admin-UI låst (kan ikke logge inn).
ADMIN_PASSWORD=                                   # 🔒 secret  ⚙ restart
# Lang tilfeldig streng. Auto-genereres hvis tom, men endring av denne
# ugyldiggjør krypterte hemmeligheter lagret i SQLite — sett én verdi
# og hold den.
ADMIN_SESSION_SECRET=                             # 🔒 secret  ⚙ restart
ADMIN_SESSION_HOURS=12

# ─────────────────────────────────────────────────────────────────────
# 9. BRANDING
# ─────────────────────────────────────────────────────────────────────
BRAND_NAME=Loki AI
BRAND_OWNER=Byggkon

# ─────────────────────────────────────────────────────────────────────
# 10. MCP-SERVER (eksterne LLM-er kobles på)
# ─────────────────────────────────────────────────────────────────────
# Når enabled=true serveres en MCP-server på /mcp som lar Claude Desktop,
# Cursor, Continue m.fl. søke i kunnskapsbasen.
MCP_ENABLED=true
# Lang tilfeldig streng — fungerer som "passord" for MCP-klienter.
# Generer med: openssl rand -hex 32
MCP_BEARER_TOKEN=                                # 🔒 secret  ⚙ restart
MCP_DEFAULT_PROVIDER=openai                       # openai | gemini
MCP_DEFAULT_TOP_K=10
