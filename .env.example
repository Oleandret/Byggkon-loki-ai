# ─── Microsoft Entra ID (app-only / client credentials) ──────────────
# Create an app registration with the following Application permissions
# (admin consent required):
#   Microsoft Graph -> Files.Read.All
#   Microsoft Graph -> Sites.Read.All        (only if syncing SharePoint)
#   Microsoft Graph -> User.Read.All         (to enumerate users' OneDrives)
GRAPH_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_ID=00000000-0000-0000-0000-000000000000
GRAPH_CLIENT_SECRET=replace-me

# ─── Sync scope ──────────────────────────────────────────────────────
# 'all_users' = enumerate every user's OneDrive in the tenant
# 'all_users_and_sharepoint' = above + every SharePoint document library
# 'users_csv' = comma-separated user UPNs (e.g. alice@contoso.com,bob@contoso.com)
# 'drives_csv' = comma-separated drive IDs (skips discovery)
SYNC_SCOPE=all_users
SYNC_USERS=
SYNC_DRIVE_IDS=

# Optional path filter — only sync items whose path starts with this prefix.
# Leave empty to sync every file in each drive.
SYNC_PATH_PREFIX=

# Skip files larger than this (bytes). Default: 50 MB.
MAX_FILE_BYTES=52428800

# ─── Scheduler ───────────────────────────────────────────────────────
# Cron expression OR interval in minutes. Interval wins if both are set.
SYNC_INTERVAL_MINUTES=10
SYNC_CRON=

# Run a sync once on startup (true/false)
SYNC_ON_STARTUP=true

# ─── OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
# Soft batch size for embedding requests
EMBEDDING_BATCH_SIZE=64

# ─── Pinecone ────────────────────────────────────────────────────────
PINECONE_API_KEY=pcn-...
PINECONE_INDEX=onedrive-knowledge
# Optional namespace; if set, every vector is written here.
# Otherwise we use the drive_id as the namespace (recommended for tenant-wide).
PINECONE_NAMESPACE=

# ─── Unstructured ────────────────────────────────────────────────────
# 'fast' for plain text/Office, 'hi_res' for layout-aware PDF/image OCR.
# 'auto' picks per file (recommended).
UNSTRUCTURED_STRATEGY=auto
# Chunking
UNSTRUCTURED_CHUNK_MAX_CHARS=1500
UNSTRUCTURED_CHUNK_OVERLAP=150

# ─── Storage ─────────────────────────────────────────────────────────
# Where the SQLite state DB lives. Mount a Railway Volume here.
STATE_DIR=/data
# Temp dir for downloads (cleaned per file). Stays inside the container.
TMP_DIR=/tmp/onedrive-sync

# ─── Runtime ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PORT=8000
# Max concurrent files being processed at once.
PROCESS_CONCURRENCY=2
